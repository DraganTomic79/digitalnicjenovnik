# HTML fajlovi — uvijek svježi, nikad keširani
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# JavaScript i CSS — revalidacija pri svakom posjetu
/*.js
  Cache-Control: no-cache, must-revalidate

/*.css
  Cache-Control: no-cache, must-revalidate

# JSON prijevodi — revalidacija (mijenjaju se sa deployom)
/*.json
  Cache-Control: no-cache, must-revalidate

# Slike i favicon — mogu se keširati (rijetko se mijenjaju)
/*.png
  Cache-Control: public, max-age=604800

/*.jpg
  Cache-Control: public, max-age=604800

/*.ico
  Cache-Control: public, max-age=604800
